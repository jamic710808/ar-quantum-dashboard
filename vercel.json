{
  "version": 2,
  "functions": {
    "api/proxy/[...path].js": {
      "regions": ["sin1", "hkg1"]
    }
  },
  "rewrites": [
    {
      "source": "/api/proxy/(.*)",
      "destination": "/api/proxy/[...path]"
    },
    {
      "source": "/api/proxy",
      "destination": "/api/proxy/[...path]"
    }
  ]
}
